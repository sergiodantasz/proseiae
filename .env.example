# Django secret key 
SECRET_KEY=CHANGE

# ON | OFF
DEBUG=ON

# Comma-separated values
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (PostgreSQL no Docker: docker compose up -d postgres)
DATABASE_URL=postgres://proseiae:proseiae@localhost:5432/proseiae
# SQLite (alternativa local): sqlite:///db.sqlite3

# Redis (run with Docker: docker compose up -d redis)
REDIS_URL=redis://localhost:6379/0
